{
  "name": "time-management-app",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered time management app with Eisenhower matrix and focus mode",
  "workspaces": [
    "backend",
    "web",
    "mobile",
    "desktop",
    "shared"
  ],
  "scripts": {
    "dev:backend": "pnpm --filter backend dev",
    "dev:web": "pnpm --filter web dev",
    "dev:mobile": "pnpm --filter mobile dev",
    "dev:desktop": "pnpm --filter desktop dev",
    "build:backend": "pnpm --filter backend build",
    "build:web": "pnpm --filter web build",
    "build:mobile": "pnpm --filter mobile build",
    "build:desktop": "pnpm --filter desktop build",
    "install:all": "pnpm install",
    "clean": "pnpm -r clean && rm -rf node_modules"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
